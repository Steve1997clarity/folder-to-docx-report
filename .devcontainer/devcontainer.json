{
  "name": "DOCX Report Generator",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "forwardPorts": [11312],
  "portsAttributes": {
    "11312": {
      "label": "DOCX Report Generator",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  },
  "postCreateCommand": "pip install -r requirements.txt",
  "postStartCommand": "nohup python main.py > /tmp/flask.log 2>&1 &",
  "customizations": {
    "codespaces": {
      "openFiles": []
    }
  }
}
